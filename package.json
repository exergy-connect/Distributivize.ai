{
  "name": "distributivize",
  "version": "0.1.0",
  "description": "Prototype developer tool for finding DCP-suitable workloads in JavaScript, Python, and Mojo projects.",
  "type": "module",
  "bin": {
    "distributivize": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "analyze:samples": "node dist/cli.js analyze ./samples",
    "generate:samples": "node dist/cli.js generate ./samples",
    "check": "npm run build && npm run analyze:samples"
  },
  "dependencies": {
    "@babel/parser": "^7.24.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
